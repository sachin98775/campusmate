{
  "info": {
    "name": "CampusMate API",
    "description": "College Attendance Management System API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000/api",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "teacherToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "studentToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"admin\",\n  \"email\": \"admin@campusmate.com\",\n  \"password\": \"Kcpadmin123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.success) {",
                  "        pm.collectionVariables.set('adminToken', response.token);",
                  "        pm.collectionVariables.set('adminUser', JSON.stringify(response.user));",
                  "    }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Teacher Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"teacher\",\n  \"teacher_code\": \"{{teacherKey}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.success) {",
                  "        pm.collectionVariables.set('teacherToken', response.token);",
                  "        pm.collectionVariables.set('teacherUser', JSON.stringify(response.user));",
                  "        console.log('Teacher logged in successfully');",
                  "    }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Student Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"student\",\n  \"className\": \"BCA 3A\",\n  \"roll_number\": \"BCA202001\",\n  \"dob\": \"2000-01-01\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.success) {",
                  "        pm.collectionVariables.set('studentToken', response.token);",
                  "        pm.collectionVariables.set('studentUser', JSON.stringify(response.user));",
                  "    }",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Admin APIs",
      "item": [
        {
          "name": "Get Dashboard",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/admin/dashboard"
          }
        },
        {
          "name": "Add Teacher",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@campusmate.com\",\n  \"phone\": \"+1234567890\",\n  \"department\": \"Computer Science\",\n  \"subjects\": [\"Data Structures\", \"Algorithms\"]\n}"
            },
            "url": "{{baseUrl}}/admin/teachers"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.success) {",
                  "        pm.collectionVariables.set('teacherKey', response.teacher.teacherKey);",
                  "        console.log('Teacher created with key: ' + response.teacher.teacherKey);",
                  "    }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Class",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"className\": \"BCA 3A\",\n  \"course\": \"BCA\",\n  \"semester\": \"3\",\n  \"description\": \"Bachelor of Computer Applications 3rd Semester\"\n}"
            },
            "url": "{{baseUrl}}/admin/classes"
          }
        },
        {
          "name": "Add Student",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Johnson\",\n  \"rollNumber\": \"BCA202001\",\n  \"dob\": \"2000-01-01\",\n  \"classId\": \"your-class-id-here\"\n}"
            },
            "url": "{{baseUrl}}/admin/add-student"
          }
        },
        {
          "name": "Add Subject to Class",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subjectName\": \"Data Structures\",\n  \"classId\": \"your-class-id-here\"\n}"
            },
            "url": "{{baseUrl}}/admin/add-subject-to-class"
          }
        },
        {
          "name": "Assign Teacher to Subject",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subjectId\": \"your-subject-id-here\",\n  \"teacherId\": \"your-teacher-id-here\"\n}"
            },
            "url": "{{baseUrl}}/admin/assign-teacher-to-subject"
          }
        },
        {
          "name": "Get All Teachers",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/admin/teachers"
          }
        },
        {
          "name": "Get All Classes",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/admin/classes"
          }
        },
        {
          "name": "Get All Students",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/admin/students"
          }
        }
      ]
    },
    {
      "name": "Teacher APIs",
      "item": [
        {
          "name": "Get Dashboard",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacherToken}}"
              }
            ],
            "url": "{{baseUrl}}/teacher/dashboard"
          }
        },
        {
          "name": "Get Assigned Classes",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacherToken}}"
              }
            ],
            "url": "{{baseUrl}}/teacher/classes"
          }
        },
        {
          "name": "Get Subjects for Class",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacherToken}}"
              }
            ],
            "url": "{{baseUrl}}/teacher/subjects?classId=your-class-id-here"
          }
        },
        {
          "name": "Get Students in Class",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacherToken}}"
              }
            ],
            "url": "{{baseUrl}}/teacher/students?subjectId=your-subject-id-here"
          }
        },
        {
          "name": "Mark Attendance",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacherToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"classId\": \"your-class-id-here\",\n  \"subjectId\": \"your-subject-id-here\",\n  \"date\": \"2024-01-15\",\n  \"attendanceData\": [\n    {\"studentId\": \"student-id-1\", \"status\": \"present\"},\n    {\"studentId\": \"student-id-2\", \"status\": \"absent\"}\n  ]\n}"
            },
            "url": "{{baseUrl}}/teacher/attendance"
          }
        },
        {
          "name": "Get Attendance for Class",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacherToken}}"
              }
            ],
            "url": "{{baseUrl}}/teacher/attendance?classId=your-class-id-here&date=2024-01-15"
          }
        }
      ]
    },
    {
      "name": "Student APIs",
      "item": [
        {
          "name": "Get Dashboard",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ],
            "url": "{{baseUrl}}/student/dashboard"
          }
        },
        {
          "name": "Get Attendance Summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ],
            "url": "{{baseUrl}}/student/attendance-summary?studentId=your-student-id-here"
          }
        },
        {
          "name": "Get Detailed Attendance",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ],
            "url": "{{baseUrl}}/student/attendance-details?studentId=your-student-id-here"
          }
        },
        {
          "name": "Get Subjects",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ],
            "url": "{{baseUrl}}/student/subjects"
          }
        },
        {
          "name": "Get Attendance Records",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ],
            "url": "{{baseUrl}}/student/attendance"
          }
        }
      ]
    }
  ]
}
